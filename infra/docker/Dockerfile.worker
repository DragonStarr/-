FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app
RUN pip install --no-cache-dir uv
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev
COPY operator_day ./operator_day
CMD ["uv", "run", "celery", "-A", "operator_day.workers.celery_app:celery_app", "worker", "--loglevel=INFO"]
